[
  {
    "name": "Two Sum",
    "topic": "Arrays",
    "difficulty": "Easy",
    "rating": 1200,
    "description": "Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target. You may assume that each input would have exactly one solution, and you may not use the same element twice.",
    "constraints": {
      "n": "2 <= N <= 100000",
      "nums[i]": "-1000000000 <= nums[i] <= 1000000000",
      "target": "-1000000000 <= target <= 1000000000"
    },
    "inputFormat": [
      "First line contains N and Target space-separated",
      "Second line contains N space-separated integers representing the array"
    ],
    "outputFormat": [
      "Print the 0-based indices of the two numbers separated by space"
    ],
    "sampleTestCases": [
      {
        "structuredInput": {
          "n": 4,
          "target": 9,
          "arr": [2, 7, 11, 15]
        },
        "input": "4 9\n2 7 11 15",
        "output": "0 1",
        "explanation": "Because nums[0] + nums[1] == 2 + 7 == 9, we return 0 1."
      },
      {
        "structuredInput": {
          "n": 3,
          "target": 6,
          "arr": [3, 2, 4]
        },
        "input": "3 6\n3 2 4",
        "output": "1 2",
        "explanation": "Because nums[1] + nums[2] == 2 + 4 == 6, we return 1 2."
      }
    ],
    "hiddenTestCases": [
      {
        "input": "2 6\n3 3",
        "output": "0 1"
      },
      {
        "input": "4 10\n1 5 5 9",
        "output": "1 2"
      },
      {
        "input": "5 0\n-3 4 3 90 1",
        "output": "0 2"
      }
    ]
  }
]

# Server configuration
PORT=5000
NODE_ENV=development

# Firebase configuration (optional for localhost, but needed for DB/Auth in prod)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----"

# Redis configuration (optional for localhost, will fallback to memory if not available)
REDIS_URL=redis://localhost:6379

# Groq API configuration (for PrepBot and ATS Scanner)
GROQ_API_KEY=gsk_your_groq_api_key_here
CLIENT_URL=http://localhost:5173
# ==========================================
# CAREERPILOT360 - SERVER ENVIRONMENT CONFIG
# ==========================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Firebase Service Account Credentials (needed for backend DB & Auth)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----"

# Redis Server URL
REDIS_URL=redis://localhost:6379

# Groq AI Developer Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# ==========================================
# CAREERPILOT360 - CLIENT ENVIRONMENT CONFIG
# ==========================================
VITE_API_BASE_URL=http://localhost:5000/api
VITE_FIREBASE_API_KEY=your-client-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-client-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-client-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-client-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-client-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-client-firebase-app-id
